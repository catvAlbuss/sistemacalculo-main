        (1 - (1 / 3) * Math.pow(this.calcs.flexocompresionEsbeltez / this.calcs.flexocompresionCk, 4));
    },
    flexocompresionColumnasLargas() {
      this.calcs.flexocompresionColumnasLargas =
        (0.329 * this.calcs.diseñoEmin * this.calcs.flexocompresionA) / Math.pow(this.calcs.flexocompresionEsbeltez, 2);
    },
    flexocompresionNadm() {
      this.calcs.flexocompresionNadm =
        this.calcs.flexocompresionEsbeltez <= 10
          ? this.calcs.flexocompresionColumnasCortas
          : this.calcs.flexocompresionEsbeltez <= this.calcs.flexocompresionCk
          ? this.calcs.flexocompresionColumnasIntermedias
          : this.calcs.flexocompresionColumnasLargas;
    },
    flexocompresionOk() {
      this.calcs.flexocompresionOk =
        this.calcs.flexocompresionNadm < this.calcs.flexocompresionAxial ? "Cambiar sección" : "ok";
    },
    flexocompresionNer() {
      this.calcs.flexocompresionNer =
        (Math.pow(Math.PI, 2) * this.calcs.diseñoEmin * this.calcs.flexocompresionLx) /
        Math.pow(this.calcs.diseñoLef * 100, 2);
    },
    flexocompresionKm() {
      this.calcs.flexocompresionKm = 1 / (1 - 1.5 * (this.calcs.flexocompresionAxial / this.calcs.flexocompresionNer));
    },
    flexocompresionEntonces() {
      this.calcs.flexocompresionEntonces =
        this.calcs.flexocompresionAxial / this.calcs.flexocompresionColumnasIntermedias +
        (this.calcs.flexocompresionKm * this.calcs.flexocompresionMomento * 100) /
          (this.calcs.flexocompresionZx * this.calcs.diseñoFm);
    },
    flexocompresionEntoncesOk() {
      this.calcs.flexocompresionEntoncesOk = this.calcs.flexocompresionEntonces > 1 ? "Cambiar sección" : "ok";
    },
    flexocompresionLc() {
      this.calcs.flexocompresionLc = this.calcs.flexocompresionEsbeltez * this.calcs.flexocompresionBcm;
    },
    flexocompresionUsar() {
      this.calcs.flexocompresionUsar = this.calcs.flexocompresionB + "x" + this.calcs.flexocompresionD;
    },

    // compresion
    compresionB() {
      this.calcs.compresionB = secciones_de_barras[this.calcs.compresionSeccion - 1].comercialB;
    },
    compresionBcm() {
      this.calcs.compresionBcm = this.calcs.compresionB * 2.54;
    },
    compresionD() {
      this.calcs.compresionD = secciones_de_barras[this.calcs.compresionSeccion - 1].comercialH;
    },
    compresionDcm() {
      this.calcs.compresionDcm = this.calcs.compresionD * 2.54;
    },
    compresionA() {
      this.calcs.compresionA = secciones_de_barras[this.calcs.compresionSeccion - 1].area;
    },
    compresionLx() {
      this.calcs.compresionLx = secciones_de_barras[this.calcs.compresionSeccion - 1].ejeXL;
    },
    compresionZx() {
      this.calcs.compresionZx = secciones_de_barras[this.calcs.compresionSeccion - 1].ejeXZ;
    },
    compresionEsbeltez() {
      this.calcs.compresionEsbeltez = (this.calcs.compresionLongitudEfectiva * 100) / this.calcs.compresionBcm;
    },
    compresionEsbeltezColumnaTipo() {
      this.calcs.compresionEsbeltezColumnaTipo =
        this.calcs.compresionEsbeltez < 10
          ? "Columna corta"
          : this.calcs.compresionEsbeltez > 10
          ? "Columna intermedia"
          : "Columna larga";
    },
    compresionCk() {
      this.calcs.compresionCk = grupo_ck[this.calcs.grupo].columnas;
    },
    compresionCkColumnaTipo() {
      this.calcs.compresionCkColumnaTipo =
        this.calcs.compresionEsbeltez < 10
          ? "Columna corta"
          : this.calcs.flexocompresionEsbeltez > 10
          ? "Columna intermedia"
          : "Columna larga";
    },
    compresionColumnasCortas() {
      this.calcs.compresionColumnasCortas = this.calcs.diseñoFc * this.calcs.compresionA;
    },
    compresionColumnasIntermedias() {
      this.calcs.compresionColumnasIntermedias =
        this.calcs.diseñoFc *
        this.calcs.compresionA *
        (1 - (1 / 3) * Math.pow(this.calcs.compresionEsbeltez / this.calcs.compresionCk, 4));
    },
    compresionColumnasLargas() {
      this.calcs.compresionColumnasLargas =
        (0.329 * this.calcs.diseñoEmin * this.calcs.compresionA) / Math.pow(this.calcs.compresionEsbeltez, 2);
    },
    compresionNadm() {
      this.calcs.compresionNadm =
        this.calcs.compresionEsbeltez <= 10
          ? this.calcs.compresionColumnasCortas
          : this.calcs.compresionEsbeltez <= this.calcs.compresionCk
          ? this.calcs.compresionColumnasIntermedias
          : this.calcs.compresionColumnasLargas;
    },
    compresionNadmOk() {
      this.calcs.compresionNadmOk =
        this.calcs.compresionNadm < this.calcs.compresionBcm * this.calcs.compresionEsbeltez ? "Cambiar sección" : "ok";
    },
    compresionUsar() {
      this.calcs.compresionUsar = this.calcs.compresionB + "x" + this.calcs.compresionD;
    },

    // traccion
    traccionAxial() {
      this.calcs.traccionAxial = 2898 / 2;
    },
    traccionNFtA() {
      this.calcs.traccionNFtA = this.calcs.diseñoFt * this.calcs.compresionA;
    },
    traccionNFtACompara() {
      this.calcs.traccionNFtACompara = this.calcs.traccionAxial;
    },
    traccionNFtAOk() {
      this.calcs.traccionNFtAOk = this.calcs.traccionNFtA > this.calcs.traccionNFtACompara ? "ok" : "Cambiar sección";
    },

    // flexotraccion
    flexotraccionBcm() {
      this.calcs.flexotraccionBcm = this.calcs.flexotraccionB * 2.54;
    },
    flexotraccionDcm() {
      this.calcs.flexotraccionDcm = this.calcs.flexotraccionD * 2.54;
    },
    flexotraccionA() {
      this.calcs.flexotraccionA = secciones_de_barras[this.calcs.flexotraccionSeccion - 1].area;
    },
    flexotraccionLx() {
      this.calcs.flexotraccionLx = secciones_de_barras[this.calcs.flexotraccionSeccion - 1].ejeXL;
    },
    flexotraccionZx() {
      this.calcs.flexotraccionZx = secciones_de_barras[this.calcs.flexotraccionSeccion - 1].ejeXZ;
    },
    flexotraccionDonde() {
      this.calcs.flexotraccionDonde =
        this.calcs.flexotraccionAxial / (this.calcs.diseñoFt * this.calcs.flexotraccionA) +
        (this.calcs.flexotraccionMomento * 100) / (this.calcs.flexotraccionZx * this.calcs.diseñoFm);
    },
    flexotraccionCambiarSeccion() {
      this.calcs.flexotraccionCambiarSeccion =
        this.calcs.flexotraccionDonde < this.calcs.flexotraccionMayorQue ? "ok" : "Cambiar sección";
    },
    flexotraccionUsar() {
      this.calcs.flexotraccionUsar = this.calcs.flexotraccionB + "x" + this.calcs.flexotraccionD;
    },
  },

  format(name, value) {
    return calcFormatters[name]?.(value) ?? isNaN(value) ? value : Number.isInteger(value) ? value : value.toFixed(2);
  },

  init() {
    Object.entries(this.formulas).forEach(([name, formula]) => {
      Alpine.effect(() => {
        formula.call(this);
      });
    });
  },
});
